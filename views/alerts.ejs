<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', {title: 'Alerts'}) %>
<body>
<%- include('partials/sidebar', {user, activePage}) %>
<main class="main">

  <header class="header">
    <div><h1>Alerts</h1><p class="subtitle">All farm notifications and warnings</p></div>
    <div class="header-actions">
      <select class="form-input" id="filter" style="width:auto;padding:8px 14px" onchange="filterAlerts()">
        <option value="all">All</option>
        <option value="active">Active</option>
        <option value="resolved">Resolved</option>
        <option value="danger">Critical</option>
        <option value="warning">Warning</option>
        <option value="info">Info</option>
        <option value="success">Success</option>
      </select>
    </div>
  </header>

  <%
    const active   = alerts.filter(a => !a.resolved);
    const resolved = alerts.filter(a => a.resolved);
    const byType   = t => alerts.filter(a => a.type === t).length;
  %>
  <section class="section">
    <div class="cards-grid">
      <div class="card"><div class="card-icon">🚨</div><div class="card-info"><div class="card-label">Critical</div><div class="card-value" style="color:var(--red)"><%= byType('danger') %></div></div></div>
      <div class="card"><div class="card-icon">⚠️</div><div class="card-info"><div class="card-label">Warnings</div><div class="card-value" style="color:var(--yellow)"><%= byType('warning') %></div></div></div>
      <div class="card"><div class="card-icon">ℹ️</div><div class="card-info"><div class="card-label">Info</div><div class="card-value" style="color:var(--blue)"><%= byType('info') %></div></div></div>
      <div class="card"><div class="card-icon">✅</div><div class="card-info"><div class="card-label">Resolved</div><div class="card-value" style="color:var(--green)"><%= resolved.length %></div></div></div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Alert Feed</h2>
    <div class="alerts-full" id="alert-feed">
      <% const icons = { danger:'🚨', warning:'⚠️', info:'ℹ️', success:'✅' };
         const labels = { danger:'CRITICAL', warning:'WARNING', info:'INFO', success:'SUCCESS' };
         alerts.forEach(a => {
           const room = rooms.find(r => r.id === a.room_id);
      %>
      <div class="alert-full-item <%= a.type %> <%= a.resolved ? 'is-resolved' : '' %>"
           data-type="<%= a.type %>" data-resolved="<%= a.resolved ? '1' : '0' %>"
           id="alert-<%= a.id %>">
        <div class="alert-full-left">
          <span class="alert-badge <%= a.type %>-badge"><%= labels[a.type] || a.type.toUpperCase() %></span>
          <span class="alert-icon-lg"><%= icons[a.type] || 'ℹ️' %></span>
        </div>
        <div class="alert-full-body">
          <div class="alert-full-title"><%= a.resolved ? '<s>' : '' %><%= a.title %><%= a.resolved ? '</s>' : '' %></div>
          <div class="alert-full-detail"><%= a.detail %></div>
          <div class="alert-full-meta">
            <% if(room){%><%= room.name %> &nbsp;·&nbsp; <% } %>
            <%= new Date(a.created_at).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
            <% if(a.resolved){ %>&nbsp;·&nbsp; <span style="color:var(--green)">Resolved</span><% } %>
          </div>
        </div>
        <div class="alert-full-actions">
          <% if (!a.resolved && (user.role === 'admin' || user.role === 'manager')) { %>
          <button class="btn-sm btn-green" onclick="resolveAlert(<%= a.id %>)">✓ Resolve</button>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </section>

</main>
<div id="toast" class="toast"></div>
<script src="/app.js"></script>
<script>
  function filterAlerts() {
    const val = document.getElementById('filter').value;
    document.querySelectorAll('.alert-full-item').forEach(el => {
      const type = el.dataset.type;
      const res  = el.dataset.resolved === '1';
      let show = val === 'all' ||
                 (val === 'active'   && !res) ||
                 (val === 'resolved' &&  res) ||
                 val === type;
      el.style.display = show ? 'flex' : 'none';
    });
  }
  async function resolveAlert(id) {
    const r = await fetch(`/api/alerts/${id}/resolve`, { method:'PUT' });
    if (r.ok) {
      showToast('Alert resolved');
      const el = document.getElementById(`alert-${id}`);
      el.classList.add('is-resolved');
      el.querySelector('.alert-full-actions').innerHTML = '';
      el.dataset.resolved = '1';
    }
  }
</script>
</body>
</html>
