<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', {title: 'Users'}) %>
<body>
<%- include('partials/sidebar', {user, activePage}) %>
<main class="main">

  <header class="header">
    <div><h1>User Management</h1><p class="subtitle">Manage farm accounts and permissions</p></div>
    <button class="btn-refresh" onclick="openCreate()">+ New User</button>
  </header>

  <section class="section">
    <div class="cards-grid">
      <div class="card"><div class="card-icon">👥</div><div class="card-info"><div class="card-label">Total Users</div><div class="card-value"><%= users.length %></div></div></div>
      <div class="card"><div class="card-icon">🔑</div><div class="card-info"><div class="card-label">Admins</div><div class="card-value"><%= users.filter(u=>u.role==='admin').length %></div></div></div>
      <div class="card"><div class="card-icon">🌿</div><div class="card-info"><div class="card-label">Managers</div><div class="card-value"><%= users.filter(u=>u.role==='manager').length %></div></div></div>
      <div class="card"><div class="card-icon">👁️</div><div class="card-info"><div class="card-label">Viewers</div><div class="card-value"><%= users.filter(u=>u.role==='viewer').length %></div></div></div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">All Accounts</h2>
    <div class="table-box">
      <table class="data-table">
        <thead><tr><th>User</th><th>Email</th><th>Role</th><th>Created</th><th>Last Login</th><th>Actions</th></tr></thead>
        <tbody>
          <% users.forEach(u => { %>
          <tr id="user-row-<%= u.id %>">
            <td>
              <div class="log-user">
                <div class="mini-avatar"><%= u.username.substring(0,2).toUpperCase() %></div>
                <strong><%= u.username %></strong>
                <% if (u.id === user.id) { %><span style="color:var(--accent);font-size:11px"> (you)</span><% } %>
              </div>
            </td>
            <td style="color:var(--muted)"><%= u.email %></td>
            <td>
              <% if (u.id === user.id) { %>
              <span class="role-badge role-<%= u.role %>"><%= u.role %></span>
              <% } else { %>
              <select class="role-select role-<%= u.role %>" onchange="changeRole(<%= u.id %>, this)">
                <option value="viewer"  <%= u.role==='viewer'  ? 'selected':'' %>>viewer</option>
                <option value="manager" <%= u.role==='manager' ? 'selected':'' %>>manager</option>
                <option value="admin"   <%= u.role==='admin'   ? 'selected':'' %>>admin</option>
              </select>
              <% } %>
            </td>
            <td style="color:var(--muted);font-size:12px">
              <%= u.created_at ? new Date(u.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '—' %>
            </td>
            <td style="color:var(--muted);font-size:12px">
              <%= u.last_login ? new Date(u.last_login).toLocaleString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : 'Never' %>
            </td>
            <td>
              <% if (u.id !== user.id) { %>
              <button class="btn-sm btn-warn" onclick="deleteUser(<%= u.id %>, '<%= u.username %>')">🗑 Delete</button>
              <% } else { %>
              <span style="color:var(--muted);font-size:12px">—</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Role permissions guide -->
  <section class="section">
    <h2 class="section-title">Role Permissions</h2>
    <div class="table-box">
      <table class="data-table">
        <thead><tr><th>Permission</th><th>Admin</th><th>Manager</th><th>Viewer</th></tr></thead>
        <tbody>
          <% const perms = [
            ['View Dashboard',   true,  true,  true ],
            ['View Rooms',       true,  true,  true ],
            ['View Analytics',   true,  true,  true ],
            ['View Alerts',      true,  true,  true ],
            ['View Logs',        true,  true,  true ],
            ['Resolve Alerts',   true,  true,  false],
            ['Control Devices',  true,  true,  false],
            ['Start New Batch',  true,  true,  false],
            ['Edit Rooms',       true,  true,  false],
            ['Delete Rooms',     true,  false, false],
            ['Manage Users',     true,  false, false],
          ]; %>
          <% perms.forEach(([label, admin, manager, viewer]) => { %>
          <tr>
            <td><%= label %></td>
            <td style="text-align:center"><%= admin   ? '✅' : '—' %></td>
            <td style="text-align:center"><%= manager ? '✅' : '—' %></td>
            <td style="text-align:center"><%= viewer  ? '✅' : '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<!-- Create User Modal -->
<div class="modal-overlay" id="modal-create" onclick="closeModal('modal-create',event)">
  <div class="modal">
    <h2>Create New User</h2>
    <div class="form-group"><label>Username</label><input type="text" id="c-user" class="form-input" placeholder="e.g. john_doe"/></div>
    <div class="form-group"><label>Email</label><input type="email" id="c-email" class="form-input" placeholder="user@example.com"/></div>
    <div class="form-group"><label>Password</label><input type="password" id="c-pass" class="form-input" placeholder="Min 6 characters"/></div>
    <div class="form-group"><label>Role</label>
      <select class="form-input" id="c-role">
        <option value="viewer">Viewer — read-only access</option>
        <option value="manager">Manager — can control devices</option>
        <option value="admin">Admin — full access</option>
      </select>
    </div>
    <div id="c-error" class="login-error" style="display:none"></div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-create')">Cancel</button>
      <button class="btn-start" onclick="createUser()">Create User</button>
    </div>
  </div>
</div>

<div id="toast" class="toast"></div>
<script src="/app.js"></script>
<script>
  function openCreate() { document.getElementById('modal-create').classList.add('active'); }
  function closeModal(id, e) {
    if (!e || e.target === document.getElementById(id))
      document.getElementById(id).classList.remove('active');
  }
  async function createUser() {
    const errEl = document.getElementById('c-error');
    const body = {
      username: document.getElementById('c-user').value.trim(),
      email:    document.getElementById('c-email').value.trim(),
      password: document.getElementById('c-pass').value,
      role:     document.getElementById('c-role').value,
    };
    const r = await fetch('/api/users', {
      method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)
    });
    const data = await r.json();
    if (!r.ok) {
      errEl.textContent = data.error;
      errEl.style.display = 'flex';
    } else {
      closeModal('modal-create');
      showToast(`User ${body.username} created!`);
      setTimeout(() => location.reload(), 800);
    }
  }
  async function changeRole(id, select) {
    const role = select.value;
    const r = await fetch(`/api/users/${id}/role`, {
      method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ role })
    });
    if (r.ok) {
      select.className = `role-select role-${role}`;
      showToast(`Role updated to ${role}`);
    } else {
      showToast('Error updating role', true);
    }
  }
  async function deleteUser(id, name) {
    if (!confirm(`Delete user "${name}"? This cannot be undone.`)) return;
    const r = await fetch(`/api/users/${id}`, { method:'DELETE' });
    if (r.ok) {
      showToast(`User ${name} deleted`);
      document.getElementById(`user-row-${id}`).remove();
    } else {
      const d = await r.json();
      showToast(d.error, true);
    }
  }
</script>
</body>
</html>
