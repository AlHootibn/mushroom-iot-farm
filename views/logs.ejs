<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', {title: 'Logs'}) %>
<body>
<%- include('partials/sidebar', {user, activePage}) %>
<main class="main">

  <header class="header">
    <div><h1>System Logs</h1><p class="subtitle">Full audit trail of all user actions and events</p></div>
    <div class="header-actions">
      <select class="form-input" id="filter-type" style="width:auto;padding:8px 14px" onchange="filterLogs()">
        <option value="">All Types</option>
        <option value="LOGIN">Login</option>
        <option value="LOGOUT">Logout</option>
        <option value="CONTROL">Control</option>
        <option value="ROOM">Room</option>
        <option value="ALERT">Alert</option>
        <option value="USER">User</option>
        <option value="PASSWORD">Password</option>
      </select>
      <button class="btn-refresh" onclick="exportLogs()">⬇ Export CSV</button>
    </div>
  </header>

  <section class="section">
    <div class="cards-grid">
      <div class="card"><div class="card-icon">📝</div><div class="card-info"><div class="card-label">Total Events</div><div class="card-value"><%= logs.length %></div></div></div>
      <div class="card"><div class="card-icon">👤</div><div class="card-info"><div class="card-label">Unique Users</div><div class="card-value"><%= [...new Set(logs.map(l=>l.username))].length %></div></div></div>
      <div class="card"><div class="card-icon">🔧</div><div class="card-info"><div class="card-label">Control Events</div><div class="card-value"><%= logs.filter(l=>l.action==='CONTROL').length %></div></div></div>
      <div class="card"><div class="card-icon">🔐</div><div class="card-info"><div class="card-label">Login Events</div><div class="card-value"><%= logs.filter(l=>l.action==='LOGIN').length %></div></div></div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Event Log</h2>
    <div class="table-box">
      <table class="data-table">
        <thead><tr><th>Timestamp</th><th>User</th><th>Action</th><th>Details</th></tr></thead>
        <tbody id="log-tbody">
          <% const actionIcons = {
            LOGIN:'🔓', LOGOUT:'🔒', CONTROL:'⚙️', ROOM_CREATE:'🏠', ROOM_UPDATE:'✏️',
            ROOM_DELETE:'🗑', ALERT_RESOLVE:'✅', USER_CREATE:'👤', USER_ROLE:'🔄',
            USER_DELETE:'❌', PASSWORD_CHANGE:'🔑'
          }; %>
          <% logs.forEach(log => { %>
          <tr class="log-row" data-action="<%= log.action %>">
            <td style="font-family:monospace;color:var(--muted);font-size:12px">
              <%= new Date(log.created_at).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit',second:'2-digit'}) %>
            </td>
            <td>
              <div class="log-user">
                <div class="mini-avatar"><%= log.username.substring(0,2).toUpperCase() %></div>
                <%= log.username %>
              </div>
            </td>
            <td>
              <code class="action-tag"><%= actionIcons[log.action] || '📋' %> <%= log.action.replace('_',' ') %></code>
            </td>
            <td style="color:var(--muted)"><%= log.detail || '—' %></td>
          </tr>
          <% }) %>
          <% if (logs.length === 0) { %>
          <tr><td colspan="4" style="text-align:center;color:var(--muted);padding:32px">No logs yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

</main>
<script src="/app.js"></script>
<script>
  const allRows = [...document.querySelectorAll('.log-row')];
  function filterLogs() {
    const val = document.getElementById('filter-type').value.toLowerCase();
    allRows.forEach(r => {
      r.style.display = (!val || r.dataset.action.toLowerCase().includes(val)) ? '' : 'none';
    });
  }
  function exportLogs() {
    const rows = allRows.filter(r => r.style.display !== 'none');
    const csv = ['Timestamp,User,Action,Details',
      ...rows.map(r => {
        const cells = r.querySelectorAll('td');
        return `"${cells[0].textContent.trim()}","${cells[1].textContent.trim()}","${cells[2].textContent.trim()}","${cells[3].textContent.trim()}"`;
      })
    ].join('\n');
    const a = document.createElement('a');
    a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
    a.download = 'mycofarm-logs.csv';
    a.click();
  }
</script>
</body>
</html>
